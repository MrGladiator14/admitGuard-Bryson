{
  "rules": [
    {
      "field": "fullName",
      "label": "Full Name",
      "inputType": "text",
      "type": "strict",
      "validation": "^[a-zA-Z\\s]{2,}$",
      "errorMessage": "Name must be at least 2 characters with no numbers.",
      "exceptionAllowed": false,
      "rationaleKeywords": []
    },
    {
      "field": "graduationYear",
      "label": "Graduation Year",
      "inputType": "number",
      "attributes": { "min": "2015", "max": "2025" },
      "type": "soft",
      "validation": "^(201[5-9]|202[0-5])$",
      "errorMessage": "Graduation year must be between 2015 and 2025 (inclusive).",
      "exceptionAllowed": true,
      "rationaleKeywords": ["approved by", "special case", "documentation pending", "waiver granted"],
      "hint": "Accepted range: 2015 to 2025."
    },
    {
      "field": "percentageCgpa",
      "label": "Percentage / CGPA",
      "inputType": "text",
      "type": "soft",
      "validation": "minPercentage:60,minCGPA:6.0",
      "errorMessage": "Minimum 60% or 6.0 CGPA (10-point scale) required.",
      "exceptionAllowed": true,
      "rationaleKeywords": ["approved by", "special case", "documentation pending", "waiver granted"],
      "hint": "Enter percentage (e.g. 72.5) or CGPA (e.g. 7.8). Values \u226510 are treated as percentage; values <10 as CGPA."
    },
    {
      "field": "screeningScore",
      "label": "Screening Test Score",
      "inputType": "number",
      "attributes": { "min": "0", "max": "100" },
      "type": "soft",
      "validation": "screeningScore",
      "errorMessage": "Screening score must be 40 or higher out of 100.",
      "exceptionAllowed": true,
      "rationaleKeywords": ["approved by", "special case", "documentation pending", "waiver granted"],
      "hint": "Score out of 100. \u226560 = Cleared | 40\u201359 = Waitlisted | <40 = Rejected (requires override)."
    }
  ]
}
